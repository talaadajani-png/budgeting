# ── Plaid ────────────────────────────────────────────────────────────────
# Get these from https://dashboard.plaid.com → Developers → Keys
PLAID_CLIENT_ID=
# Use the SANDBOX secret for fake test data, or the PRODUCTION secret for real
# bank data. They are different values — make sure PLAID_SECRET matches PLAID_ENV.
PLAID_SECRET=
# "sandbox" (fake test data, login user_good / pass_good) or "production" (real data).
PLAID_ENV=sandbox
# Comma-separated country codes Plaid Link offers. Use "CA" for Canadian banks,
# "US" for US, or "US,CA" for both. Your Plaid account must be enabled for these.
PLAID_COUNTRY_CODES=US
# Required for OAuth banks (Chase, BofA, Capital One, etc.) in production.
# Must be an HTTPS URL registered under Plaid dashboard → Developers → Allowed
# redirect URIs. Leave blank for sandbox / credential-only banks.
# PLAID_REDIRECT_URI=https://your-app.example.com/

# ── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API. Use the SERVICE-ROLE key (server-only, never shipped
# to the browser). Run supabase/schema.sql in the SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────
# node scripts/hash-password.mjs "your-password"   (already $-escaped for .env)
APP_PASSWORD_HASH=
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
