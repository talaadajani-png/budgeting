# ── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API. Use the SERVICE-ROLE key (server-only, never shipped
# to the browser). Run supabase/schema.sql in the SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────
# node scripts/hash-password.mjs "your-password"
# In a local .env.local use the $-escaped output the script prints; in a hosting
# dashboard (e.g. Netlify) paste the RAW bcrypt hash without backslashes.
APP_PASSWORD_HASH=
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Ingest (optional) ────────────────────────────────────────────────────
# Bearer token for POST /api/ingest, used to push transactions from outside the
# browser (e.g. an assistant parsing a pasted statement). Leave unset to disable.
# node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
INGEST_TOKEN=

